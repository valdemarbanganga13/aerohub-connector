{
  "name": "aerohub-connector",
  "version": "1.0.0",
  "description": "AeroHub Connector for Discord Rich Presence",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -mw"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aerohub.connector",
    "productName": "AeroHub Connector",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  }
}
